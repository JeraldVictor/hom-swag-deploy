# ============================================================
# HomSwag Deploy — Environment Variables
# Copy to .env.local or .env.prod and fill in the values.
#
# This file is loaded by:
#   - compose.yaml     → infra service config (ports, credentials)
#   - server container → full runtime config via env_file
# ============================================================

# ── GHCR image tags ──────────────────────────────────────────
# Set to a specific digest/tag to pin a release, or leave as "latest".
SERVER_IMAGE_TAG=latest
ADMIN_IMAGE_TAG=latest
APP_IMAGE_TAG=latest

# ── Exposed ports (host-side) ─────────────────────────────────
SERVER_PORT=3000
ADMIN_PORT=3001
APP_PORT=3002
MONGO_PORT=27017
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
# Redis is internal only — no external port is exposed

# ── Volume source overrides (optional) ───────────────────────
# Uncomment to mount a host path instead of a named Docker volume.
# MONGODB_DATA_SOURCE=/data/homswag/mongodb
# MINIO_DATA_SOURCE=/data/homswag/minio
UPLOAD_SOURCE=./uploads
LOG_PATH=./logs

# ─────────────────────────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
APP_NAME=HomSwag
APP_URL=https://api.homswag.com

# WARNING: SKIP_AUTH bypasses all authentication.
# Will throw an error and refuse to start if enabled in production.
SKIP_AUTH=false

CORS_ALLOWED_ORIGINS=https://admin.homswag.com,https://app.homswag.com

# ─────────────────────────────────────────────────────────────
# LOGGER
# ─────────────────────────────────────────────────────────────
LOG_LEVEL=info
ENABLE_OTEL=false
OTEL_ENDPOINT=http://localhost:4318/v1/logs
# Set true only in development/QA — exposes stack traces in HTTP responses
ERROR_INCLUDE_STACK=false

# ─────────────────────────────────────────────────────────────
# MONGODB
# ─────────────────────────────────────────────────────────────
MONGO_USER=admin
MONGO_PASSWORD=changeme_strong_password
MONGODB_URI=mongodb://admin:changeme_strong_password@mongodb:27017/homswag?authSource=admin

# ─────────────────────────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PASSWORD=changeme_strong_password

# ─────────────────────────────────────────────────────────────
# MINIO (S3-compatible object storage)
# ─────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_strong_password
MINIO_ENABLED=true
MINIO_ENDPOINT=minio
MINIO_BUCKET=media
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme_strong_password
MINIO_USE_SSL=false

# ─────────────────────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=604800
JWT_REFRESH_SECRET=change_this_refresh_secret
JWT_REFRESH_EXPIRES_IN=2592000
BFF_JWT_ACCESS_SECRET=change_this_bff_access_secret
BFF_JWT_REFRESH_SECRET=change_this_bff_refresh_secret

# ─────────────────────────────────────────────────────────────
# RATE LIMITING
# ─────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=false
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─────────────────────────────────────────────────────────────
# MEDIA STORAGE
# ─────────────────────────────────────────────────────────────
MEDIA_STORAGE_TYPE=minio
LOCAL_UPLOAD_DIR=uploads
LOCAL_PUBLIC_PATH=/uploads
MAX_FILE_SIZE=10485760
IMAGE_MAX_WIDTH=2048
IMAGE_MAX_HEIGHT=2048
IMAGE_QUALITY=85
THUMBNAIL_WIDTH=300
THUMBNAIL_HEIGHT=300
CDN_URL=
CDN_ENABLED=false

# ─────────────────────────────────────────────────────────────
# EMAIL (Zeptomail)
# ─────────────────────────────────────────────────────────────
ENABLE_EMAIL=false
ZEPTOMAIL_API_KEY=
ZEPTOMAIL_API_URL=https://api.zeptomail.com
ZEPTOMAIL_FROM_EMAIL=noreply@homswag.com
ZEPTOMAIL_FROM_NAME=HomSwag

# ─────────────────────────────────────────────────────────────
# PAYMENT (ZohoPay)
# ─────────────────────────────────────────────────────────────
ZOHOPAY_AUTH_TOKEN=
ZOHOPAY_API_BASE_URL=https://payments.zoho.in/api/v1

# ─────────────────────────────────────────────────────────────
# GOOGLE MAPS
# ─────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ─────────────────────────────────────────────────────────────
# FEATURES
# ─────────────────────────────────────────────────────────────
ENABLE_CACHE=true
ENABLE_ANALYTICS=false
AUTOMATIC_ORDER_ASSIGN_ENABLED=false

# ─────────────────────────────────────────────────────────────
# SWAGGER / API DOCS (disable in production)
# ─────────────────────────────────────────────────────────────
ENABLE_SWAGGER=false

# ─────────────────────────────────────────────────────────────
# DEV — SKIP AUTH (development only)
# ─────────────────────────────────────────────────────────────
DEV_SYSTEM_STAFF_ID=
DEV_SYSTEM_OFFICE_ID=
